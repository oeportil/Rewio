// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  password     String
  role         userRole
  dui          String?
  status       Boolean
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  logicDel     Boolean      @default(false)
  clinicsOwned Clinic[]
  doctor       Doctor?
  patient      Patient?
  clinicUsers  ClinicUser[]
}

model Clinic {
  id      Int     @id @default(autoincrement())
  name    String
  slug    String  @unique
  phone   String
  email   String  @unique
  address String
  logo    String
  status  Boolean
  ownerId Int

  owner User @relation(fields: [ownerId], references: [id])

  doctors      Doctor[]
  patients     Patient[]
  services     Service[]
  appointments Appointment[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  clinicUsers ClinicUser[]
}

model Doctor {
  id        Int     @id @default(autoincrement())
  clinicId  Int
  userId    Int     @unique
  specialty String
  color     String
  active    Boolean @default(true)

  schedules       DoctorSchedule[]
  appointments    Appointment[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  clinic          Clinic           @relation(fields: [clinicId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  doctorBlocks    DoctorBlock[]
  doctorVacations DoctorVacation[]

  @@unique([clinicId, userId])
}

model Patient {
  id       Int @id @default(autoincrement())
  clinicId Int
  userId   Int @unique

  phone     String?
  birthdate DateTime?
  notes     String?

  clinic Clinic @relation(fields: [clinicId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([clinicId, userId])
}

model Service {
  id           Int           @id @default(autoincrement())
  clinicId     Int
  name         String
  duration     Int
  price        Float
  color        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
}

model DoctorSchedule {
  id        Int    @id @default(autoincrement())
  doctorId  Int
  weekday   Int // 0-6
  startTime String
  endTime   String

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, weekday])
}

model Appointment {
  id Int @id @default(autoincrement())

  clinicId  Int
  doctorId  Int
  patientId Int
  serviceId Int

  date      DateTime
  startTime String
  endTime   String
  status    AppointmentStatus @default(pending)
  notes     String?

  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  createdAt              DateTime                @default(now())
  appointmentReschedules AppointmentReschedule[]
  appointmentReminders   AppointmentReminder[]

  @@unique([doctorId, date, startTime])
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  done
}

enum userRole {
  admin
  clinic
  doctor
  patient
}

model ClinicUser {
  id       Int        @id @default(autoincrement())
  clinicId Int
  userId   Int
  role     ClinicRole
  status   Boolean    @default(true)

  clinic Clinic @relation(fields: [clinicId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([clinicId, userId])
}

enum ClinicRole {
  owner
  admin
  doctor
  receptionist
}

model DoctorBlock {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      DateTime
  startTime String
  endTime   String
  reason    String?

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId, date])
}

model DoctorVacation {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  startDate DateTime
  endDate   DateTime
  reason    String?
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model AppointmentReschedule {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  oldDate       DateTime
  oldStartTime  String
  oldEndTime    String
  newDate       DateTime
  newStartTime  String
  newEndTime    String
  reason        String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model AppointmentReminder {
  id            Int             @id @default(autoincrement())
  appointmentId Int
  sendAt        DateTime
  channel       ReminderChannel
  sent          Boolean         @default(false)

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

enum ReminderChannel {
  email
  sms
  whatsapp
}

//para idempotencia en backend, OJO siempre es de implementar los loaders en el frontend pero esto
//agrega una capa mas de seguridad para evitar las cosas repetidas en los post
model IdempotencyKey {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  response    Json
  status_code Int
  createdAt   DateTime @default(now())
}

